{
  "name": "boilerplate",
  "version": "1.0.0",
  "description": "Express, sass and mustache boilerplate",
  "main": "app.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "compile:sass": "sass --watch sass/main.scss public/css/main.css",
    "start": "sass sass/main.scss public/css/main.css && nodemon app.js"
  },
  "author": "Jhonatan Tomimatsu",
  "license": "ISC",
  "devDependencies": {
    "sass": "^1.77.0"
  },
  "dependencies": {
    "body-parser": "^1.19.0",
    "dotenv": "^6.0.0",
    "express": "^4.16.4",
    "express-router": "0.0.1",
    "mustache-express": "^1.2.8",
    "nodemon": "^1.18.4",
    "pg": "^7.14.0",
    "serve-favicon": "^2.5.0"
  }
}
