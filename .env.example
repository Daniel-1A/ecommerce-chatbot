# ──────────────────────────────────────────────
# Ecommerce Chatbot — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env:   cp .env.example .env
# Then adjust values to match your local setup.

# ── App ──────────────────────────────────────
# Port the Express server listens on (default: 3000)
PORT=3000

# ── PostgreSQL ───────────────────────────────
# Database user (must have CONNECT + CRUD privileges on DB_NAME)
DB_USER=ebot_user

# Database password
DB_PASSWORD=ebot_pass

# Hostname — use "localhost" for local, "db" for docker-compose
DB_HOST=localhost

# Database name (must already exist; see db/init.sql)
DB_NAME=ebot

# PostgreSQL port (default: 5432)
DB_PORT=5432
